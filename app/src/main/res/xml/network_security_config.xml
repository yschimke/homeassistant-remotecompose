<?xml version="1.0" encoding="utf-8"?>
<!--
  Cleartext policy for Terrazzo.

  Android 9+ blocks cleartext HTTP unless we opt in here. HA on a LAN is
  routinely served as plain HTTP at an RFC1918 address (e.g.
  `http://192.168.1.50:8123`) or an mDNS hostname (e.g.
  `http://homeassistant.local:8123`), and Android's
  network-security-config can't express either "any RFC1918 IP" or "any
  Wi-Fi network" — domain/IP entries match by suffix or exact literal
  only. Enumerating private-IP ranges in XML is impractical (no CIDR /
  wildcard support), so the real gate lives in
  `LanConnectionPolicy.kt`: it rejects cleartext to non-LAN destinations
  and cleartext over cellular at the connect entry point.

  HTTPS to public hosts (Nabu Casa, reverse proxies) still works
  unchanged.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <!--
          Trust both the OS-shipped CAs (Let's Encrypt, DigiCert, …) and
          CAs the user installed via Settings → Security → Encryption &
          credentials. Since Android 7 (API 24), apps don't trust
          user-installed CAs unless they opt in here.

          HA self-hosters routinely run an internal CA (mkcert,
          smallstep, Caddy internal, pfSense) and install its root on
          the phone so `https://homeassistant.lan:8123` validates. Same
          choice the HA companion app makes. Tradeoff: a malicious or
          MDM-pushed CA could MITM HTTPS — acceptable for an HA client,
          not for a banking app.
        -->
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
