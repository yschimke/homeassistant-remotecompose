<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- mDNS discovery for _home-assistant._tcp instances on the LAN. -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />
    <!-- User-initiated 15-min monitoring window (foreground service + its notification). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".TerrazzoApplication"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="Terrazzo"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@android:style/Theme.Material.Light.NoActionBar">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          AppAuth redirect receiver. Catches the `rcha://auth-callback`
          return after the HA sign-in web flow and hands the code to
          AppAuth for token exchange.
        -->
        <activity
            android:name="net.openid.appauth.RedirectUriReceiverActivity"
            android:exported="true"
            tools:node="replace"
            xmlns:tools="http://schemas.android.com/tools">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="${appAuthRedirectScheme}"
                      android:host="auth-callback" />
            </intent-filter>
        </activity>

        <!--
          Per-card home-screen widget. One declaration, many pinned
          instances — each pinned widget gets a unique `appWidgetId`
          that keys into DataStore to find its card config.
        -->
        <receiver
            android:name=".widget.TerrazzoWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/terrazzo_widget_info" />
        </receiver>

        <!-- Fires after requestPinAppWidget is confirmed by the user. -->
        <receiver
            android:name=".widget.WidgetInstallReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="ee.schimke.terrazzo.WIDGET_PIN_CONFIRMED" />
            </intent-filter>
        </receiver>

        <!--
          User-initiated bounded-window monitoring of a single card.
          `dataSync` fits the "poll state on a timer for 15 min" shape;
          the service self-stops at the window end, so the foreground
          promise stays bounded.
        -->
        <service
            android:name=".monitor.MonitoringService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
    </application>
</manifest>
