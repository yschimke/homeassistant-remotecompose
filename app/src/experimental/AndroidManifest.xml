<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- User-initiated 15-min monitoring window (foreground service + its notification). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <application>
        <!--
          User-initiated bounded-window monitoring of a single card.
          `dataSync` fits the "poll state on a timer for 15 min" shape;
          the service self-stops at the window end, so the foreground
          promise stays bounded.
        -->
        <service
            android:name=".monitor.MonitoringService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
    </application>
</manifest>
