<?xml version="1.0" encoding="utf-8"?>
<!--
  Glance Wear widget provider descriptor — large container variant.
  Shared across the 5 Slot{N}LargeWidgetService entries; per-slot
  identity (which slot index, which pinned card) is resolved at render
  time from the WearOfflineStore keyed off the service's component
  name.

  previewImage is a placeholder vector for now — a follow-up renders
  the wear @Preview functions to PNG and wires the rendered drawables
  in here.
-->
<wearwidget-provider
    label="Terrazzo slot"
    description="Renders the card assigned to this Wear slot from the phone."
    preferredType="@integer/glance_wear_container_type_large"
    previewImage="@drawable/wear_slot_preview_large">
    <container
        type="@integer/glance_wear_container_type_large"
        previewImage="@drawable/wear_slot_preview_large" />
</wearwidget-provider>
