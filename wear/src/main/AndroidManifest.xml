                android:resource="@xml/wear_slot_widget_provider_large" />
        </service>

        <!-- Slot 4 -->
        <service
            android:name=".widget.Slot3SmallWidgetService"
            android:exported="true"
            android:enabled="false"
            android:label="Terrazzo slot 4 (small)">
            <intent-filter>
                <action android:name="androidx.glance.wear.action.BIND_WIDGET_PROVIDER" />
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>
            <meta-data
                android:name="androidx.glance.wear.widget.provider"
                android:resource="@xml/wear_slot_widget_provider_small" />
        </service>
        <service
            android:name=".widget.Slot3LargeWidgetService"
            android:exported="true"
            android:enabled="false"
            android:label="Terrazzo slot 4 (large)">
            <intent-filter>
                <action android:name="androidx.glance.wear.action.BIND_WIDGET_PROVIDER" />
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>
            <meta-data
                android:name="androidx.glance.wear.widget.provider"
                android:resource="@xml/wear_slot_widget_provider_large" />
        </service>

        <!-- Slot 5 -->
        <service
            android:name=".widget.Slot4SmallWidgetService"
            android:exported="true"
            android:enabled="false"
            android:label="Terrazzo slot 5 (small)">
            <intent-filter>
                <action android:name="androidx.glance.wear.action.BIND_WIDGET_PROVIDER" />
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>
            <meta-data
                android:name="androidx.glance.wear.widget.provider"
                android:resource="@xml/wear_slot_widget_provider_small" />
        </service>
        <service
            android:name=".widget.Slot4LargeWidgetService"
            android:exported="true"
            android:enabled="false"
            android:label="Terrazzo slot 5 (large)">
            <intent-filter>
                <action android:name="androidx.glance.wear.action.BIND_WIDGET_PROVIDER" />
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>
            <meta-data
                android:name="androidx.glance.wear.widget.provider"
                android:resource="@xml/wear_slot_widget_provider_large" />
        </service>
    </application>
</manifest>
