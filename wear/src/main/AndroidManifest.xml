        <service
            android:name=".widget.Slot1LargeWidgetService"
            android:exported="true"
            android:enabled="false"
            android:label="Terrazzo slot 2 (large)">
            <intent-filter>
                <action android:name="androidx.glance.wear.action.BIND_WIDGET_PROVIDER" />
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>
            <meta-data
                android:name="androidx.glance.wear.widget.provider"
                android:resource="@xml/wear_slot_widget_provider_large" />
        </service>

        <!-- Slot 3 -->
        <service
            android:name=".widget.Slot2SmallWidgetService"
            android:exported="true"
            android:enabled="false"
            android:label="Terrazzo slot 3 (small)">
            <intent-filter>
                <action android:name="androidx.glance.wear.action.BIND_WIDGET_PROVIDER" />
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
