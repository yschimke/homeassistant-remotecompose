# Copy to .env.local (gitignored) and fill in after first-boot onboarding.
#
# Host port to expose HA on. Default 8124 to avoid clashing with an existing
# HA instance on 8123. Container-internal port is always 8123.
HA_HOST_PORT=8124

# Long-lived access token issued from HA's Profile → Security panel.
HA_TOKEN=

# Optional: override if you run capture.mjs outside the compose network.
# Inside the `puppeteer` service (network_mode: service:homeassistant),
# keep the default — HA is reachable at 127.0.0.1:8123 on that namespace.
# HA_URL=http://127.0.0.1:8123
